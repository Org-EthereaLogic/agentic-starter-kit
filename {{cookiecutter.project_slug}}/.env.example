# Example environment file for {{ cookiecutter.project_name }}.
#
# Copy to `.env` and fill in real values. `.env` is gitignored;
# only `.env.example` is committed (per IMP-001 / general secrets
# hygiene). Treat every value here as a placeholder.

# --- Project metadata -----------------------------------------------------

PROJECT_NAME="{{ cookiecutter.project_name }}"
PROJECT_SLUG="{{ cookiecutter.project_slug }}"

{% if cookiecutter.include_codacy == "yes" %}# --- Codacy ---------------------------------------------------------------
# Used by `make codacy-local` and `.github/workflows/ci.yml` job
# `codacy`. Get the project token from
# https://app.codacy.com/<org>/<repo>/settings/integrations
CODACY_PROJECT_TOKEN=<codacy-project-token>

{% endif %}{% if cookiecutter.include_codecov == "yes" %}# --- Codecov --------------------------------------------------------------
# Used by `.github/workflows/ci.yml` job `codecov`. Public repos
# can omit this; private repos must set it.
CODECOV_TOKEN=<codecov-upload-token>

{% endif %}{% if cookiecutter.include_snyk == "yes" %}# --- Snyk -----------------------------------------------------------------
# Used by `make snyk-local` and `.github/workflows/ci.yml` job
# `snyk`. Get the API token from https://app.snyk.io/account
SNYK_TOKEN=<snyk-api-token>

{% endif %}# --- Add your project-specific variables below ----------------------------
# Each entry should have a one-line comment naming where the value
# comes from and which subsystem reads it.
