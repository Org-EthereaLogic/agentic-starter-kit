{
  "name": "{{ cookiecutter.project_slug }}",
  "version": "0.1.0",
  "description": "{{ cookiecutter.project_description }}",
  "private": true,
  "license": "{% if cookiecutter.license == 'Proprietary' %}UNLICENSED{% else %}{{ cookiecutter.license }}{% endif %}",
  "author": {
    "name": "{{ cookiecutter.author_name }}",
    "email": "{{ cookiecutter.author_email }}"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.js tests/test_*.js tests/*.test.cjs tests/test_*.cjs",
    "test:watch": "node --test --watch tests/*.test.js tests/test_*.js tests/*.test.cjs tests/test_*.cjs",
    "coverage": "node --test --experimental-test-coverage tests/*.test.js tests/test_*.js tests/*.test.cjs tests/test_*.cjs",
    "hooks-test": "node --test tests/test_pre_tool_use_hook.js"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.6",
    "eslint": "^9",
    "@typescript-eslint/parser": "^8",
    "@typescript-eslint/eslint-plugin": "^8",
    "prettier": "^3.3"
  }
}
